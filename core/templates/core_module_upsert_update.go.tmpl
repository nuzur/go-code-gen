package {{.Package}}

{{$entityName := .EntityName}}
{{$projectIdentifier := .Project.Identifier}}
{{$projectModule := .Project.Module}}
{{$entityDir := .Project.EntitiesConfig.Dir}}
{{$entityIdentifier := .EntityIdentifier}}
{{$imports := .Imports}}
import (
	"context"
    "errors"
		
	{{if eq .Project.MonitoringConfig.Enabled true}}
	"{{.Project.Module}}/monitoring"
	{{end}}
	"{{.Project.Module}}/{{.Project.CoreConfig.CoreDir}}/module/{{.EntityIdentifier}}/types"	
	{{.Project.Identifier}}db "{{.Project.Module}}/{{.Project.CoreConfig.CoreDir}}/{{.Project.CoreConfig.RepoConfig.Dir}}/gen"   	
	{{$firstJSON := true}}
	{{$firstEnumMany := true}}
	{{range $field := .Fields}}				
		{{if eq $firstJSON true}}
			{{if eq $field.JSON true}}
				{{range $import := $imports}} {{if and (ne $import "time") (ne $import "github.com/gofrs/uuid") (ne $import (printf "%s/enum" $projectModule)) (ne $import "github.com/guregu/null/v6")}} 
    			"{{$import}}" {{end}}{{end}}
				{{$firstJSON = false}}
			{{end}}
		{{end}}
		{{if eq $firstEnumMany true}}
			{{if eq $field.EnumMany true}}
				main_entity "{{$projectModule}}/{{$entityDir}}/{{$entityIdentifier}}"
				{{$firstEnumMany = false}}
			{{end}}
		{{end}}
	{{end}}
	{{if eq .HasVersionField true}}
	"time"
	{{end}}
	{{if or (eq .HasArrayField true) (eq .HasNullUUID true)}}
	"{{$projectModule}}/{{$entityDir}}/mapper"
	{{end}}
	
)

func (m *module) Update(
	ctx context.Context, 
	req types.UpsertRequest, 
	partial bool, 
	opts ...Option,
) (types.UpsertResponse, error) {
	optConfig := applyAllOptions(opts)

	tx := optConfig.SQLTx
	createdTx := false
	if tx == nil {
		ntx, err := m.repository.DB.Begin()
		if err != nil {
			return types.UpsertResponse{}, err
		}
		tx = ntx
		defer tx.Rollback()
		createdTx = true
	}

	qtx := m.repository.Queries.WithTx(tx)
	existing, err := qtx.Fetch{{.EntityName}}By{{.PrimaryKeysName}}ForUpdate(ctx, 
		{{range $pk := .PrimaryKeys}}{{$pk.RepoToMapperUpsert}}, {{end}}
	)
	if err != nil {
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "error fetching existing record for Upsert{{.EntityName}} - with uuid",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.ModuleServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})
		{{end}}
		return types.UpsertResponse{}, err
	}

	if len(existing) == 0 {
		err := errors.New("entity not found")
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "not found existing record for Upsert{{.EntityName}} - with uuid",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.ModuleServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})
		{{end}}
		return types.UpsertResponse{}, err
	}

	{{if eq .HasVersionField true}}
	if existing[0].Version != req.{{.EntityName}}.Version {
		err := errors.New("upsert version conflict")
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "version conflict Upsert{{.EntityName}}",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.ModuleServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})
		{{end}}
		return types.UpsertResponse{}, err
	}

	req.{{.EntityName}}.Version = time.Now().Unix()
	{{end}}


	params := mapUpsertRequestToUpdateParams(req, existing[0], partial)
	err = qtx.Update{{.EntityName}}(
		ctx,
		params,
	)
	if err != nil {
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "error calling repository for Upsert{{.EntityName}} - with uuid",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.RepositoryServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})	
		{{end}}		
		return types.UpsertResponse{}, err
	}

	{{if eq .ShouldPublishEvents true}}
	err = m.publishUpdateEvent(ctx, req, qtx, existing)
	if err != nil {
		return types.UpsertResponse{}, err
	}
	{{end}}

	if createdTx {
		err := tx.Commit()
		if err != nil {
			{{if eq .Project.MonitoringConfig.Enabled true}}
			m.monitoring.Emit(monitoring.EmitRequest{
				ActionIdentifier: "upsert_{{.EntityIdentifier}}",
				Message:          "error commiting for Upsert{{.EntityName}}",
				EntityIdentifier: "{{.EntityIdentifier}}",
				Layer:            monitoring.RepositoryServiceLayer,
				Type:             monitoring.EmitTypeError,
				Data:             req,
				Error:            err,
			})
			{{end}}
			return types.UpsertResponse{}, err
		}
	}
	
	{{if eq .Project.MonitoringConfig.Enabled true}}
	m.monitoring.Emit(monitoring.EmitRequest{
		ActionIdentifier: "upsert_{{.EntityIdentifier}}",
		Message: "successfully handled Upsert{{.EntityName}} - with uuid",
		EntityIdentifier: "{{.EntityIdentifier}}",
		Layer: monitoring.ModuleServiceLayer,
		Type: monitoring.EmitTypeSuccess,
		Data: req,			
	})
	{{end}}

	return buildUpdateResponse(req), nil	
}

func buildUpdateResponse(req types.UpsertRequest) types.UpsertResponse {
	return types.UpsertResponse{
		{{range $pk := .PrimaryKeys}}
		{{$pk.Name}}: req.{{$entityName}}.{{$pk.Name}},
		{{end}}
	}
}

func mapUpsertRequestToUpdateParams(req types.UpsertRequest, existing {{.Project.Identifier}}db.{{.EntityName}}, partial bool) {{.Project.Identifier}}db.Update{{.EntityName}}Params {	
	if !partial {
		return {{.Project.Identifier}}db.Update{{.EntityName}}Params{ {{range $field := .Fields}}			
			{{$field.Name}}: {{$field.RepoToMapperUpsert}}, 			
			{{end}}
		}
	}

	res := {{.Project.Identifier}}db.Update{{.EntityName}}Params{}
	
	{{range $field := .Fields}}
	{{- if $field.IsKey}}
	res.{{$field.Name}} = {{$field.RepoToMapperUpsert}}
	{{- else}}
	if {{$field.PartialUpdateCheck}} {
		res.{{$field.Name}} = {{$field.RepoToMapperUpsert}}
	} else {
		res.{{$field.Name}} = existing.{{$field.Name}}
	}
	{{- end}}
	{{end}}

	return res

}


{{if eq .ShouldPublishEvents true}}
func (m *module) publishUpdateEvent(ctx context.Context, 
		req types.UpsertRequest, 
		qtx *{{.Project.Identifier}}db.Queries,		
		existing []{{.Project.Identifier}}db.{{.EntityName}}) error {

	if m.events == nil {
		return nil
	}
	fetched, err := qtx.Fetch{{.EntityName}}By{{.PrimaryKeysName}}(ctx, 
		{{range $pk := .PrimaryKeys}}{{$pk.RepoToMapperUpsert}}, {{end}}
	)
	if err != nil {
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "error fetching after Upsert{{.EntityName}} - with uuid",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.RepositoryServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})
		{{end}}
		return err
	}
	
	fetchedEntities := mapModelsToEntities(fetched)
	if len(fetchedEntities) != 1 {
		return errors.New("error mapping to entity")
	}	
	existingEntities := mapModelsToEntities(existing)	
	err = m.events.ProduceEntityUpdated(fetchedEntities[0], existingEntities[0])
	if err != nil {
		{{if eq .Project.MonitoringConfig.Enabled true}}
		m.monitoring.Emit(monitoring.EmitRequest{
			ActionIdentifier: "upsert_{{.EntityIdentifier}}",
			Message: "error producing insert event for Upsert{{.EntityName}} - with uuid",
			EntityIdentifier: "{{.EntityIdentifier}}",
			Layer: monitoring.RepositoryServiceLayer,
			Type: monitoring.EmitTypeError,
			Data: req,
			Error: err,
		})
		{{end}}
		return err
	}
	return nil
}
{{end}}