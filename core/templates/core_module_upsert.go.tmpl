package {{.Package}}

import (
	"context"    
	
	"github.com/gofrs/uuid"	
	"{{.Project.Module}}/{{.Project.CoreConfig.CoreDir}}/module/{{.EntityIdentifier}}/types"		
)

func (m *module) Upsert(
	ctx context.Context, 
	req types.UpsertRequest, 
	partial bool, 
	opts ...Option,
) (types.UpsertResponse, error) {
	// check if primary keys are set to determine if this is an insert or update	
	isInsert := true
	{{range $pk := .PrimaryKeys}}
	if req.{{$.EntityName}}.{{$pk.Name}} != {{$pk.ZeroValue}} {		
		isInsert = false
	}
	{{end}}

	if isInsert {		
		return m.Insert(ctx, req, opts...)
	}

	return m.Update(ctx, req, partial, opts...)
}

