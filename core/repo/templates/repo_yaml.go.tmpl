version: "2"
sql:
  - engine: "{{.Project.CoreConfig.RepoConfig.DatabaseType}}"
    schema: "sql/schema/create.sql"
    queries: "sql/queries/"
    gen:
      go:
        emit_exact_table_names: true
        package: "{{.Project.Identifier}}db"
        out: "gen"
        emit_interface: true
        emit_json_tags: true
        rename: {{range $identifier, $camelCase := .Fields}}
          {{$identifier}}: {{ $camelCase }}{{end}}        
        overrides:          
          - db_type: {{if eq .Project.CoreConfig.RepoConfig.DatabaseType "mysql"}}"int"{{else}}"pg_catalog.int4"{{end}}            
            go_type:              
              type: "int64"
          - db_type: "json"            
            go_type:
              type: "[]byte"  # workaround sqlc bug when reading null json columns            
          - db_type: "json"  
            nullable: true            
            go_type:
              type: "[]byte"  # workaround sqlc bug when reading null json columns            
          - db_type: datetime
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Time"
          - db_type: date
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Time"
          - db_type: time
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Time"
          - db_type: varchar
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "String"
          - db_type: char
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "String"
          - db_type: text
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "String"
          - db_type: {{if eq .Project.CoreConfig.RepoConfig.DatabaseType "mysql"}}"int"{{else}}"pg_catalog.int4"{{end}}
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Int"
          - db_type: float
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Float"
          - db_type: double
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Float"
          - db_type: double
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Float"
          - db_type: tinyint
            nullable: true            
            go_type:
              import: "github.com/guregu/null/v6"
              package: "null"
              type: "Bool"
overrides:
  go: 
    rename:{{range $identifier, $camelCase := .Entities}}
      {{$identifier}}: {{ $camelCase }}{{end}}