apiVersion: v1
kind: Pod
metadata:
  name: "{{ "{{" }} include "{{.Identifier}}.fullname" . {{ "}}" }}-test-connection"
  labels:
    {{ "{{-" }} include "{{.Identifier}}.labels" . | nindent 4 {{ "}}" }}
  annotations:
    "helm.sh/hook": test
spec:
  containers:
    - name: grpc-check
      image: busybox
      command: ['nc', '-z', '-w', '3']
      args: ['{{ "{{" }} include "{{.Identifier}}.fullname" . {{ "}}" }}', '{{ "{{" }} .Values.service.grpcPort {{ "}}" }}']
  restartPolicy: Never
