package main
import (
	"net/http"
	"go.uber.org/fx"
	"go.uber.org/zap"
	"go.uber.org/config"
	{{.Identifier}}config "{{.Module}}/config"
	"{{.Module}}/{{.CoreConfig.CoreDir}}"

	{{ if and .ProtoConfig.Enabled .ProtoConfig.Server }}
	pbserver "{{.Module}}/idl/server"		
	{{end}}

	{{ if .AuthConfig.Enabled }}
	{{.AuthImport}}
	{{ end }}

	{{ if .MonitoringConfig.Enabled }}
	"{{.Module}}/monitoring"
	{{ end }}
	
	{{if eq .CoreConfig.EventsConfig.Enabled true}}
	"{{.Module}}/{{.CoreConfig.CoreDir}}/{{.CoreConfig.EventsConfig.Dir}}"
	{{end}}

	{{if eq .KafkaEnabled true}}
	saramafx "github.com/mklfarha/sarama-fx"	
	{{end}}
)

func main() {
	fx.New(
		fx.Provide(
			zap.NewProduction,
			{{.Identifier}}config.New,
			core.New,	
			{{ if .MonitoringConfig.Enabled }}monitoring.New,{{end}}
			{{ if ne .AuthImport ""}}auth.New,{{end}}			
			{{ if eq .CoreConfig.EventsConfig.Enabled true}}events.New,{{end}}
		),	
		fx.Invoke(httpServer),
		{{ if eq .KafkaEnabled true }}saramafx.Module,{{end}}		
		{{ if and .ProtoConfig.Enabled .ProtoConfig.Server }}fx.Invoke(pbserver.New),{{end}}		
	).Run()
}


func httpServer(config config.Provider, logger *zap.Logger){
	// http port from config 
	httpPort := config.Get("ports.http").String()

	go http.ListenAndServe(":"+httpPort, nil)

	logger.Info(`Serving HTTP on PORT: %s`, zap.String("port", httpPort))
}

